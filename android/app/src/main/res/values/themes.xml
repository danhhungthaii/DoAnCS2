<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Base.Theme.AttendanceApp" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowBackground">@color/background</item>
    </style>

    <style name="Theme.AttendanceApp" parent="Base.Theme.AttendanceApp" />
    
    <!-- Alias for AndroidManifest compatibility -->
    <style name="Theme.AttendanceQR" parent="Theme.AttendanceApp" />

    <!-- Fullscreen theme for QR Scanner -->
    <style name="Theme.AttendanceApp.Fullscreen" parent="Theme.AttendanceApp">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
</resources>
